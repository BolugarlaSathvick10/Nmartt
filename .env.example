# Database Configuration
# Required for production: Use PostgreSQL connection string
# Examples:
#   - Vercel Postgres: postgresql://username:password@host:5432/database
#   - Neon: postgresql://user:password@host/database
#   - Railway: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/nmart

# Data Source Mode
# local: Uses Zustand/localStorage (for development/testing)
# api: Uses Next.js API routes and database
# Default for production should be 'api'
NEXT_PUBLIC_DATA_SOURCE_MODE=local

# Node Environment
# Development, production, or test
NODE_ENV=development
